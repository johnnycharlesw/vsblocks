{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"esModuleInterop": true,
		"removeComments": false,
		"preserveConstEnums": true,
		"sourceMap": false,
		"allowJs": true,
		"resolveJsonModule": true,
		"isolatedModules": false,
		"outDir": "../out/vs",
		"types": [
			"@webgpu/types",
			"mocha",
			"semver",
			"sinon",
			"trusted-types",
			"winreg",
			"wicg-file-system-access"
		],
		"plugins": [
			{
				"name": "tsec",
				"exemptionConfig": "./tsec.exemptions.json"
			}
		]
	},
	"include": [
		"./*.ts",
		"./typings",
		"./vs/**/*.ts",
		"vsblocks-dts/vscode.proposed.*.d.ts",
		"vsblocks-dts/vscode.d.ts"
, "vsblocks-dts/vsblocks.proposed.quickPickSortByLabel.d.ts", "vsblocks-dts/vsblocks.proposed.canonicalUriProvider.d.ts", "vsblocks-dts/vsblocks.proposed.authSession.d.ts", "vsblocks-dts/vsblocks.proposed.authProviderSpecific.d.ts", "vsblocks-dts/vsblocks.proposed.authLearnMore.d.ts", "vsblocks-dts/vsblocks.proposed.authIssuers.d.ts", "vsblocks-dts/vsblocks.proposed.authenticationChallenges.d.ts", "vsblocks-dts/vsblocks.proposed.aiTextSearchProvider.d.ts", "vsblocks-dts/vsblocks.proposed.tunnels.d.ts", "vsblocks-dts/vsblocks.proposed.valueSelectionInQuickPick.d.ts", "vsblocks-dts/vsblocks.proposed.aiSettingsSearch.d.ts"	],
	"exclude": [
		"vs/workbench/contrib/webview/browser/pre/service-worker.js"
	]
}
